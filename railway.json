{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
          "builder": "NIXPACKS"
    },
    "deploy": {
          "startCommand": "export LD_LIBRARY_PATH=/opt/scholarhive-libs:/root/.nix-profile/lib:/root/.nix-profile/lib64:$LD_LIBRARY_PATH && export PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers && cd backend && /opt/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port $PORT",
          "healthcheckPath": "/health",
          "healthcheckTimeout": 120
    }
}
